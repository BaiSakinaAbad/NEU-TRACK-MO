rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if the current user is an admin
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    // User Profile Rules
    match /users/{userId} {
      // Allow any authenticated user to read/write their own profile
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // MOA Rules
    match /moas/{moaId} {
      // Allow reading and listing MOAs for any authenticated user
      allow read, list: if isAuthenticated();
      
      // Only Admins can create, update, or manage MOAs
      allow write: if isAdmin();
    }

    // Audit Log Rules
    match /audit_logs/{logId} {
      // Only Admins can view the audit trail
      allow read, list: if isAdmin();
      
      // Any authenticated action can create a log entry
      allow create: if isAuthenticated();
      
      // Logs are immutable
      allow update, delete: if false;
    }
  }
}