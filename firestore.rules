rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated and has correct domain
    function isAuthenticated() {
      return request.auth != null && 
             request.auth.token.email != null && 
             request.auth.token.email.endsWith('@neu.edu.ph');
    }

    // Helper to check if the current user is an admin
    // We check the role directly from the user's document
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    // User Profile Rules
    match /users/{userId} {
      // Allow any authenticated user to read their own profile
      // Admins can read any profile
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      // Allow a user to create/update their own profile
      // Admins can manage all profiles
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // MOA Rules
    match /moas/{moaId} {
      // Allow reading and listing MOAs for any institutional user
      allow read, list: if isAuthenticated();
      
      // Only Admins can create, update, or soft-delete MOAs
      allow write: if isAdmin();
    }

    // Audit Log Rules
    match /audit_logs/{logId} {
      // Only Admins can view the audit trail
      allow read, list: if isAdmin();
      
      // Any authenticated action can create a log entry
      allow create: if isAuthenticated();
      
      // Logs are immutable
      allow update, delete: if false;
    }
  }
}