rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to get the user's role from their document
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // User Profile Rules
    match /users/{userId} {
      // Allow users to read their own profile or Admins to read any profile
      allow read: if isAuthenticated() && (request.auth.uid == userId || getUserRole() == 'ADMIN');
      
      // Allow users to create their own initial profile
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Allow users to update their own profile (except role) or Admins to update anything
      allow update: if isAuthenticated() && (request.auth.uid == userId || getUserRole() == 'ADMIN');
      
      // Only Admins can delete users
      allow delete: if isAuthenticated() && getUserRole() == 'ADMIN';
    }

    // MOA Rules
    match /moas/{moaId} {
      // Any authenticated user can read and list MOAs
      // (The UI handles filtering specific views for Students)
      allow read, list: if isAuthenticated();
      
      // Only Admins and Faculty can create, update, or manage MOAs
      allow write: if isAuthenticated() && (getUserRole() == 'ADMIN' || getUserRole() == 'FACULTY');
    }

    // Audit Log Rules
    match /audit_logs/{logId} {
      // Only Admins can view the audit trail
      allow read, list: if isAuthenticated() && getUserRole() == 'ADMIN';
      
      // Any authenticated action can create a log entry
      allow create: if isAuthenticated();
      
      // Logs are immutable
      allow update, delete: if false;
    }
  }
}